datadir="/var/lib/proxysql"
errorlog="/var/lib/proxysql/proxysql.log"

admin_variables=
{
        admin_credentials="admin:admin"
        pgsql_ifaces="0.0.0.0:6132"
        pgsql-monitor_username="monitor"
        pgsql-monitor_password="monitor"
}

pgsql_variables=
{
        interfaces="0.0.0.0:6133"
}

# Defines all the PostgreSQL servers
pgsql_servers =
(
      {
              address = "postgres_db" # The actual container name on the Docker network
              port = 5432             # The internal Docker port
              hostgroup = 1
              status = "ONLINE"
              weight = 1
              max_connections = 100
      }
)

# Defines all the PostgreSQL users
pgsql_users =
(
      {
              username = "postgres" 
              password = "password" # Make sure this exactly matches your .env POSTGRES_PASSWORD
              default_hostgroup = 1
              active = 1
      }
      {
        username = "sana" 
        password = "Connect360" 
        default_hostgroup = 1
        active = 1
      }
)
